# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Settings -> API -> service_role key.
# SERVER-ONLY — do NOT add a NEXT_PUBLIC_ prefix to this one. It bypasses
# Row Level Security and is used only in server actions that must run before
# a user has an account yet (creating a new church at signup).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to build the magic-link redirect URL in server actions, where there's
# no browser `window.location` to read from. Your deployed URL in production
# (e.g. https://remember.yourdomain.com); http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
